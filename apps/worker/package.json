{
  "name": "@ai-sports-prediction/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/worker.ts",
    "migrate:postgres": "tsx src/jobs/migrate-postgres.ts",
    "migrate:outreach": "tsx src/jobs/migrate-outreach-postgres.ts",
    "backup:postgres": "tsx src/jobs/export-postgres-backup.ts",
    "queue:backup": "tsx src/jobs/enqueue-postgres-backup.ts",
    "verify:postgres-backup": "tsx src/jobs/verify-postgres-backup.ts",
    "outreach:discover": "tsx src/jobs/discover-editorial-outreach-cli.ts",
    "outreach:backfill-drafts": "tsx src/jobs/backfill-editorial-outreach-drafts.ts",
    "outreach:approve": "tsx src/jobs/approve-editorial-outreach-cli.ts",
    "outreach:send": "tsx src/jobs/send-editorial-outreach-cli.ts",
    "test:outreach": "node --import tsx src/editorial-outreach-agent.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sports-prediction/db": "0.1.0",
    "@ai-sports-prediction/llm": "0.1.0",
    "@aws-sdk/client-s3": "latest",
    "bullmq": "latest",
    "tsx": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
