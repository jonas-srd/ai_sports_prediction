{
  "name": "ai-sports-prediction",
  "version": "0.1.0",
  "private": true,
  "description": "AI sport prediction platform for comparing football forecasts from multiple models.",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/worker",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/run-with-env.mjs npm run dev --workspace @ai-sports-prediction/web",
    "dev:frontend": "node scripts/run-with-env.mjs next dev apps/web --webpack -H 127.0.0.1 -p 3000",
    "dev:api": "node scripts/run-with-env.mjs node --import tsx apps/api/src/server.ts",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start:web",
    "start:web": "npm run start --workspace @ai-sports-prediction/web",
    "start:api": "node scripts/run-with-env.mjs node --import tsx apps/api/src/server.ts",
    "start:worker": "node scripts/run-with-env.mjs node --import tsx apps/worker/src/worker.ts",
    "test:analytics": "node --import tsx apps/web/src/lib/benchmark-analytics.test.ts",
    "test:special": "node --import tsx packages/llm/src/special-questions.test.ts",
    "load:test": "node scripts/load-test.mjs",
    "aws:deploy-cloudflare-edge": "node scripts/deploy-cloudflare-edge.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:migrate:postgres": "node scripts/run-with-env.mjs node --import tsx apps/worker/src/jobs/migrate-postgres.ts",
    "backup:postgres": "node scripts/run-with-env.mjs node --import tsx apps/worker/src/jobs/export-postgres-backup.ts",
    "queue:backup": "node scripts/run-with-env.mjs node --import tsx apps/worker/src/jobs/enqueue-postgres-backup.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
