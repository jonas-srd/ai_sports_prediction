# OpenRouter is used as the single gateway for all LLM predictions.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=AI Sport Prediction
OPENROUTER_TEST_MODEL=openai/gpt-5.5
# Optional comma-separated override. Leave empty to use the minimal flagship MVP list.
OPENROUTER_MODEL_IDS=
# Optional benchmark completion ceilings. Defaults are fixed at 5000 so retries
# do not receive a different token budget than first attempts.
OPENROUTER_BENCHMARK_MAX_COMPLETION_TOKENS=
OPENROUTER_BENCHMARK_RETRY_MAX_COMPLETION_TOKENS=
OPENROUTER_BENCHMARK_REPAIR_MAX_COMPLETION_TOKENS=
# Optional special-question completion ceilings. Defaults are fixed at 9000
# because these prompts ask for full team probability distributions.
OPENROUTER_SPECIAL_MAX_COMPLETION_TOKENS=
OPENROUTER_SPECIAL_RETRY_MAX_COMPLETION_TOKENS=
OPENROUTER_SPECIAL_REPAIR_MAX_COMPLETION_TOKENS=

# Primary football data provider for World Cup fixtures/results.
# Keep this in .env only. Do not prefix it with NEXT_PUBLIC.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026

# Public website analytics. This is a public Google Analytics 4 measurement ID.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-YVTSCGG16P

# API-Football dashboard key from https://dashboard.api-football.com/#.
# Keep this in .env/.env.local only. Do not prefix it with NEXT_PUBLIC.
API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# API-Sports live data for non-football sport pages. Keep keys server-side only.
# API_SPORTS_KEY can be reused for API-NBA, API-NFL and API-Tennis if your
# API-Sports plan enables those products. Sport-specific keys override it.
API_SPORTS_KEY=
API_SPORTS_NFL_KEY=
API_SPORTS_NBA_KEY=
API_SPORTS_TENNIS_KEY=
API_TENNIS_KEY=
API_SPORTS_CACHE_SECONDS=300
API_SPORTS_MATCH_LIMIT=8
API_TENNIS_CACHE_SECONDS=60

# Optional API-Sports sport config.
API_NFL_LEAGUE_ID=1
API_NFL_SEASON=2026
API_NBA_LEAGUE=standard
API_NBA_SEASON=2026
API_TENNIS_MATCH_LIMIT=24

# Optional API-Football league overrides by slug.
API_FOOTBALL_BUNDESLIGA_LEAGUE_ID=78
API_FOOTBALL_DFB_POKAL_LEAGUE_ID=81
API_FOOTBALL_PREMIER_LEAGUE_LEAGUE_ID=39
API_FOOTBALL_FA_CUP_LEAGUE_ID=45
API_FOOTBALL_LA_LIGA_LEAGUE_ID=140
API_FOOTBALL_COPA_DEL_REY_LEAGUE_ID=143
API_FOOTBALL_LIGUE_1_LEAGUE_ID=61
API_FOOTBALL_COUPE_DE_FRANCE_LEAGUE_ID=66
API_FOOTBALL_SERIE_A_LEAGUE_ID=135
API_FOOTBALL_COPPA_ITALIA_LEAGUE_ID=137
API_FOOTBALL_CHAMPIONS_LEAGUE_LEAGUE_ID=2
API_FOOTBALL_EUROPA_LEAGUE_LEAGUE_ID=3
API_FOOTBALL_CONFERENCE_LEAGUE_LEAGUE_ID=848

# Production backend. Postgres is the production source of truth.
DATABASE_URL=
DATABASE_SSL=1
DATABASE_SSL_REJECT_UNAUTHORIZED=1

# Dedicated API and worker services.
SERVICE_ROLE=web
AI_SPORTS_API_URL=
INTERNAL_API_URL=
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
ADMIN_API_TOKEN=
REDIS_URL=

# Postgres logical exports. Use local files by default and S3-compatible object
# storage in production.
POSTGRES_BACKUP_DIR=exports/postgres-backups
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=ai-sports-prediction/backups
BACKUP_S3_REGION=
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=0
