# OpenRouter is used as the single gateway for all LLM predictions.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=AI Sport Prediction
OPENROUTER_TEST_MODEL=openai/gpt-oss-20b:free
# Optional comma-separated override. Leave empty to use the minimal flagship MVP list.
OPENROUTER_MODEL_IDS=openai/gpt-oss-20b:free
# Optional benchmark completion ceilings. Defaults are fixed at 5000 so retries
# do not receive a different token budget than first attempts.
OPENROUTER_BENCHMARK_MAX_COMPLETION_TOKENS=
OPENROUTER_BENCHMARK_RETRY_MAX_COMPLETION_TOKENS=
OPENROUTER_BENCHMARK_REPAIR_MAX_COMPLETION_TOKENS=
# Optional special-question completion ceilings. Defaults are fixed at 9000
# because these prompts ask for full team probability distributions.
OPENROUTER_SPECIAL_MAX_COMPLETION_TOKENS=
OPENROUTER_SPECIAL_RETRY_MAX_COMPLETION_TOKENS=
OPENROUTER_SPECIAL_REPAIR_MAX_COMPLETION_TOKENS=

# Public website analytics. This is a public Google Analytics 4 measurement ID.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-KSGFX9TKD8

# TheSportsDB Premium. Keep the real key only in .env/.env.local.
THE_SPORTS_DB_API_KEY=
THE_SPORTSDB_API_KEY=
THE_SPORTS_DB_CACHE_SECONDS=300
THE_SPORTS_DB_LIVE_CACHE_SECONDS=60
THE_SPORTS_DB_TABLE_CACHE_SECONDS=300
THE_SPORTS_DB_FETCH_TIMEOUT_MS=6000
THE_SPORTS_DB_MATCH_LIMIT=1500
THE_SPORTS_DB_DAY_SCAN_DAYS=28
THE_SPORTS_DB_SEASON=

# Bookmaker odds via The Odds API. Keep the real key only in .env/.env.local.
THE_ODDS_API_KEY=
THE_ODDS_API_REGIONS=eu,us
THE_ODDS_API_CACHE_SECONDS=300
THE_ODDS_API_FETCH_TIMEOUT_MS=6000
# Recheck real bookmaker odds throughout the final seven days before kickoff.
ODDS_REFRESH_LOOKAHEAD_DAYS=7
ODDS_REFRESH_INTERVAL_MINUTES=60
ODDS_REFRESH_MIN_AGE_MINUTES=60
ODDS_REFRESH_MAX_MATCHES_PER_RUN=250

# Production backend. Postgres is the production source of truth.
DATABASE_URL=
DATABASE_SSL=1
DATABASE_SSL_REJECT_UNAUTHORIZED=1

# Dedicated API and worker services.
SERVICE_ROLE=web
AI_SPORTS_API_URL=
INTERNAL_API_URL=
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
ADMIN_API_TOKEN=
# Private cockpit login. Keep the allowlist and real secrets outside version
# control. ADMIN_TOTP_SECRETS is a JSON object mapping each email to a unique
# Base32 authenticator secret.
ADMIN_ACCESS_EMAILS=
ADMIN_SESSION_SECRET=
ADMIN_TOTP_SECRETS=
ADMIN_SESSION_TTL_HOURS=168
REDIS_URL=
API_CACHE_ODDS_TTL_SECONDS=60
WEB_API_ODDS_CACHE_SECONDS=60

# Worker automation: scans Sport API fixtures and creates missing predictions
# once fixtures are within the configured lookahead window.
PREDICTION_AUTOMATION_LOOKAHEAD_DAYS=7
PREDICTION_AUTOMATION_INTERVAL_MINUTES=60
PREDICTION_AUTOMATION_MAX_NEW_PER_RUN=50

# Newsletter sending via Resend. Keep the real API key only in .env/.env.local
# or AWS Secrets Manager.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL="AI Sports Prediction <ai-sports-prediction@outlook.com>"
NEWSLETTER_IP_HASH_SALT=

# Sports-publisher research and permission-gated outreach. Search queries are
# separated with |. Discovery creates review drafts only and never sends email.
# SerpApi is the default when SERPAPI_API_KEY is configured; Brave remains supported.
OUTREACH_SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
# Optional separate database for local outreach development. Production can omit
# this to use the main DATABASE_URL.
OUTREACH_DATABASE_URL=
OUTREACH_DATABASE_SSL=0
OUTREACH_SEARCH_QUERIES="Sportmagazin Deutschland Redaktion Kontakt|Fußball Nachrichten Redaktion Kontakt|Sport News Portal Deutschland Impressum Redaktion"
OUTREACH_SEARCH_COUNTRY=DE
OUTREACH_SEARCH_LANGUAGE=de
# Default language for generated outreach email drafts. The cockpit can override it per run.
OUTREACH_EMAIL_LANGUAGE=de
OUTREACH_RESULTS_PER_QUERY=10
OUTREACH_MAX_DOMAINS_PER_RUN=20
OUTREACH_MAX_CRAWL_ATTEMPTS_PER_RUN=60
OUTREACH_MAX_CONTACT_PAGES=4
OUTREACH_MIN_FIT_SCORE=45
OUTREACH_FETCH_TIMEOUT_MS=8000
OUTREACH_CRAWL_DELAY_MS=1200
OUTREACH_BOT_CONTACT_URL=https://www.ai-sports-prediction.net/de/impressum
OUTREACH_OPENROUTER_MODEL=
OUTREACH_FROM_EMAIL="AI Sports Prediction <widgets@your-verified-domain.example>"
OUTREACH_REPLY_TO_EMAIL=widgets@your-verified-domain.example

# Multi-stage marketing agent: prediction selection -> copy -> visual -> compliance -> publishing.
# All generated marketing copy and visual text is always English.
# "review" creates drafts only. "auto" approves and publishes newly created campaigns;
# only enable it after testing every configured account and subreddit.
MARKETING_AUTOMATION_ENABLED=0
MARKETING_PUBLISH_MODE=review
MARKETING_AUTOMATION_INTERVAL_MINUTES=180
MARKETING_MAX_CAMPAIGNS_PER_RUN=5
MARKETING_LOOKAHEAD_DAYS=3
MARKETING_MIN_CONFIDENCE=55
MARKETING_TIMEZONE=Europe/Berlin
MARKETING_OPENROUTER_MODEL=
MARKETING_ASSET_DIR=exports/marketing-assets
# Public HTTPS base from which Meta can fetch generated JPEGs. Do not add a trailing slash.
MARKETING_PUBLIC_ASSET_BASE_URL=
MARKETING_PREDICTION_URL=https://www.ai-sports-prediction.net
# Optional S3-compatible upload. The public base URL must map to this bucket/prefix.
MARKETING_ASSET_S3_BUCKET=
MARKETING_ASSET_S3_PREFIX=marketing-assets
MARKETING_ASSET_S3_REGION=eu-central-1
MARKETING_ASSET_S3_ENDPOINT=
MARKETING_ASSET_S3_FORCE_PATH_STYLE=0

# Reach/click feedback agent. It stores time-series snapshots and writes concrete recommendations.
MARKETING_ANALYTICS_ENABLED=0
MARKETING_ANALYTICS_INTERVAL_MINUTES=360
MARKETING_ANALYTICS_LOOKBACK_DAYS=30
MARKETING_ANALYTICS_MAX_POSTS_PER_RUN=100
MARKETING_ANALYTICS_OPENROUTER_MODEL=

# Instagram requires a professional account. Stories require a Business account.
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_API_VERSION=v23.0

# OAuth 2 user access token with post.write/media.write permissions.
X_USER_ACCESS_TOKEN=

# TikTok Content Posting API. The safe default uploads an editable photo draft.
# DIRECT_POST requires TikTok audit approval and the video.publish scope.
TIKTOK_ACCESS_TOKEN=
TIKTOK_POST_MODE=MEDIA_UPLOAD
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# Comma-separated allowlist without r/. The agent never chooses communities by itself.
MARKETING_REDDIT_SUBREDDITS=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT="web:ai-sports-prediction-marketing:v1.0 (by /u/your-account)"

# Paid editorial widgets. Store real publisher keys only in secret env vars.
# Use keyHash values in production: sha256:<sha256-of-publisher-key>.
WIDGET_ACCESS_KEYS='[{"name":"Example Publisher","keyHash":"sha256:replace-with-hash","status":"active","plan":"growth","domains":["example.com"],"monthlyLimit":250000}]'
# Stripe-hosted SEPA Direct Debit checkout for paid widgets. Create all prices in EUR.
# Monthly prices recur monthly. Annual prices charge 11 monthly fees for the first 12 months;
# the webhook then schedules a switch to the regular monthly price after the minimum term.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
WIDGET_CHECKOUT_ORIGIN=https://www.ai-sports-prediction.net
WIDGET_ACCESS_FROM_EMAIL="AI Sports Prediction <widgets@your-verified-domain.example>"

# Postgres logical exports. Use local files by default and S3-compatible object
# storage in production.
POSTGRES_BACKUP_DIR=exports/postgres-backups
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=ai-sports-prediction/backups
BACKUP_S3_REGION=
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=0
