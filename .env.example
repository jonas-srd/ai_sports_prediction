# OpenRouter is used as the single gateway for all LLM predictions.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=World Cup LLM Rank

# Supabase stores matches, predictions, and scores.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional football data provider for fixture/result sync.
FOOTBALL_DATA_API_KEY=

# Used to protect deployed cron endpoints later.
CRON_SECRET=
